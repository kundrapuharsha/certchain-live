# ═══════════════════════════════════════════════════════════
# CertChain — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ── Blockchain ───────────────────────────────────────────────
# Get free RPC from https://alchemy.com → Create App → Sepolia
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployer wallet private key (export from MetaMask)
# This wallet pays gas for deployment and registering institutions
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Get free API key from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# ── Pinata IPFS (PDF Storage) ─────────────────────────────────
# Free account at https://pinata.cloud → 1GB free
# Developers → API Keys → New Key → Admin
PINATA_JWT=YOUR_PINATA_JWT_TOKEN
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── SendGrid Email ───────────────────────────────────────────
# Free account at https://sendgrid.com → 100 emails/day free
# Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.YOUR_SENDGRID_KEY
EMAIL_FROM=certificates@youruniversity.edu
EMAIL_FROM_NAME=University Certificate Registry

# ── Frontend (React — prefix with REACT_APP_) ───────────────
REACT_APP_PINATA_JWT=YOUR_PINATA_JWT_TOKEN
REACT_APP_PINATA_GATEWAY=https://gateway.pinata.cloud
REACT_APP_NOTIFY_API_URL=https://your-api.vercel.app/api/notify
REACT_APP_NETWORK=sepolia
REACT_APP_SITE_URL=https://certchain.vercel.app

# ── Vercel API (for email serverless function) ───────────────
# These are set automatically in Vercel dashboard — not needed locally
# SENDGRID_API_KEY (set in Vercel environment variables)
